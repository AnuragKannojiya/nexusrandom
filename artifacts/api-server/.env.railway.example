# --- Copy these into Railway → Variables tab ---

# Your Netlify site URL (no trailing slash)
# e.g. https://nexusrandom.netlify.app
ALLOWED_ORIGIN=https://your-site.netlify.app

# Your moderation dashboard password (set in Replit Secrets already — copy same value here)
ADMIN_SECRET=your-strong-password-here

# Session secret for signed cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=your-random-session-secret-here

# Database URL — Railway provides this automatically if you add a PostgreSQL plugin
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Node environment
NODE_ENV=production

# Railway sets PORT automatically — do not set this manually
# PORT=8080
